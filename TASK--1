from transformers import AutoTokenizer, AutoModelForSeq2SeqLM
import textwrap

def run_alternative_summarization_tool():
    model_name = "facebook/bart-large-cnn"
    tokenizer = AutoTokenizer.from_pretrained(model_name)
    model = AutoModelForSeq2SeqLM.from_pretrained(model_name)

    article = """
    Artificial intelligence (AI) is intelligence demonstrated by machines, as opposed to the natural intelligence
    displayed by animals including humans. AI research has been defined as the field of study of intelligent agents,
    which refers to any system that perceives its environment and takes actions that maximize its chance of achieving
    its goals. Beyond the hype, AI has become a staple of modern technology, powering everything from web searches
    to autonomous vehicles. However, the rapid development of AI also brings concerns about ethics, job displacement,
    and the potential for biased decision-making. Researchers are currently focusing on making AI more 'explainable'
    so that humans can understand why a machine makes a specific decision, which is crucial for applications in
    healthcare and law.
    """

    print("--- ORIGINAL ARTICLE (Alternative Approach) ---")
    print(textwrap.fill(article, 80))

    print("\n" + "="*30)
    print("GENERATING SUMMARY (Alternative Approach)... (This may take a few seconds)")
    print("="*30 + "\n")

    # Tokenize the input text
    inputs = tokenizer([article], max_length=1024, return_tensors="pt", truncation=True)

    # Generate summary IDs
    summary_ids = model.generate(
        inputs["input_ids"],
        num_beams=4,
        min_length=30,
        max_length=100,
        early_stopping=True
    )

    # Decode the generated summary
    summary_text = tokenizer.decode(summary_ids[0], skip_special_tokens=True)

    print("--- CONCISE SUMMARY (Alternative Approach) ---")
    print(textwrap.fill(summary_text, 80))

# Execute the alternative tool
run_alternative_summarization_tool()
